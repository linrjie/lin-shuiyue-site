---
import stageImage from '../assets/images/blog-stage-bg.png';
---

<section class="blog-stage" id="blog-stage" aria-labelledby="blog-stage-title" style={`--stage-image: url(${stageImage.src})`}>
  <div class="blog-stage-overlay" aria-hidden="true"></div>
  <div class="blog-stage-title">
    <p>ANIME NOTES · NIGHT RADIO · DAILY LOG</p>
    <h2 id="blog-stage-title">linshuiyue<span>の</span>blog</h2>
    <small>一些兴趣、碎片和突然想记住的瞬间</small>
  </div>
  <div class="barrage-physics" id="barrage-physics" aria-hidden="true"></div>
  <button class="barrage-replay" id="barrage-replay" type="button">重放弹幕</button>
  <a class="blog-stage-next" href="#about">继续翻页 ↓</a>
</section>
