---
import heroImage from '../assets/images/anime-hero.png';
---

<section class="hero start-hero" id="home" style={`--hero-image: url(${heroImage.src})`}>
  <div class="start-overlay" aria-hidden="true"></div>
  <div class="start-panel">
    <p class="start-greeting">WELCOME TO SHUIYUE'S WORLD</p>
    <time class="clock" id="clock" datetime="00:00:00">00:00:00</time>
    <p class="calendar" id="calendar">正在读取今天的日期……</p>
    <form class="search-form" action="https://www.bing.com/search" method="get" target="_blank" role="search">
      <label class="sr-only" for="site-search">搜索内容</label>
      <span class="search-engine" aria-hidden="true">搜</span>
      <input id="site-search" name="q" type="search" autocomplete="off" placeholder="输入想搜索的内容" required />
      <button type="submit" aria-label="开始搜索">⌕</button>
    </form>
    <p class="start-quote">“今晚的月色，也替我欢迎你。”</p>
  </div>
  <a class="scroll-down" href="#blog-stage" aria-label="前往 Blog 舞台">进入第二屏 <span>↓</span></a>
</section>
