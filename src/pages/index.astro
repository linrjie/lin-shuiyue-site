---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Hero from '../components/Hero.astro';
import BlogStage from '../components/BlogStage.astro';
import About from '../components/About.astro';
import ContentShelf from '../components/ContentShelf.astro';
import Guestbook from '../components/Guestbook.astro';
import SettingsPanel from '../components/SettingsPanel.astro';
import PetConsole from '../components/PetConsole.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout>
  <SiteHeader />
  <main>
    <Hero />
    <BlogStage />
    <About />
    <ContentShelf posts={posts.slice(0, 6)} />
    <Guestbook />
  </main>
  <footer><p>© <span id="year"></span> 林水月的小站</p><p>写给朋友，也写给路过的你</p></footer>
  <SettingsPanel />
  <PetConsole />
</BaseLayout>
